{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "npm install && npm install --prefix app && npm install --prefix brain",
  "buildCommand": "npm run build --prefix app",
  "outputDirectory": "app/dist",
  "functions": {
    "api/index.ts": {
      "maxDuration": 300,
      "includeFiles": "{app/src/lib/brain/snapshot.json,brain/data/sourced-companies.json,brain/src/**}"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api?p=$1" },
    { "source": "/((?!api/?$).*)", "destination": "/index.html" }
  ]
}
